<?xml version="1.0" encoding="utf-8" ?>
<widget id="soprasteria.timelinerangepicker.TimelineRangePicker"
        pluginWidget="true"
        needsEntityContext="true"
        offlineCapable="true"
        xmlns="http://www.mendix.com/widget/1.0/"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.mendix.com/widget/1.0/ ../../node_modules/mendix/custom_widget.xsd">

    <name>Timeline Range Picker</name>
    <description>Select a time range via an interactive timeline with drag handles, snapping, and dark/light mode.</description>
    <icon/>
    <properties>
        <!-- Mendix Attributes -->
        <propertyGroup caption="Data">
            <property key="startTime" type="attribute">
                <caption>Start time</caption>
                <description>DateTime attribute — start of the selected range</description>
                <attributeTypes>
                    <attributeType name="DateTime"/>
                </attributeTypes>
            </property>
            <property key="endTime" type="attribute">
                <caption>End time</caption>
                <description>DateTime attribute — end of the selected range</description>
                <attributeTypes>
                    <attributeType name="DateTime"/>
                </attributeTypes>
            </property>
            <property key="duration" type="attribute">
                <caption>Duration (minutes)</caption>
                <description>Integer attribute — auto-calculated as (endTime - startTime) in minutes</description>
                <attributeTypes>
                    <attributeType name="Integer"/>
                </attributeTypes>
            </property>
        </propertyGroup>

        <!-- Timeline Configuration -->
        <propertyGroup caption="Timeline">
            <property key="rangeStart" type="integer" defaultValue="0">
                <caption>Range start (minutes)</caption>
                <description>Start of the visible timeline in minutes from midnight (0 = 00:00)</description>
            </property>
            <property key="rangeEnd" type="integer" defaultValue="1440">
                <caption>Range end (minutes)</caption>
                <description>End of the visible timeline in minutes from midnight (1440 = 24:00)</description>
            </property>
            <property key="snapMinutes" type="enumeration" defaultValue="fifteen">
                <caption>Snap interval</caption>
                <description>Handles snap to the nearest interval</description>
                <enumerationValues>
                    <enumerationValue key="one">1 minute</enumerationValue>
                    <enumerationValue key="five">5 minutes</enumerationValue>
                    <enumerationValue key="fifteen">15 minutes</enumerationValue>
                    <enumerationValue key="thirty">30 minutes</enumerationValue>
                </enumerationValues>
            </property>
        </propertyGroup>
    </properties>
</widget>
